{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/api/auth/login" },
    { "source": "/api/questions/:id", "destination": "/api/questions/[id]" },
    { "source": "/api/sessions/:id", "destination": "/api/sessions/[id]" },
    { "source": "/api/sessions/:id/answers", "destination": "/api/sessions/[id]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api|@|src|node_modules).*)", "destination": "/index.html" }
  ]
}
